#include "torabo_tsuki_lp.dtsi"
#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>

&zip_temp_layer {
    excluded-positions = <
        16 // J left
        17 // K middle
        18 // L right
        28 // M prev
        30 // . next
    >;
};

&pointing_listener {
    input-processors = <
        &zip_xy_transform (INPUT_TRANSFORM_X_INVERT | INPUT_TRANSFORM_Y_INVERT)
        &zip_temp_layer 1 800
    >;
    //レイヤー1をオートマウスレイヤに設定　800msec有効

    slow_pointer {
        layers = <9>;
        input-processors = <
            &zip_xy_transform (INPUT_TRANSFORM_X_INVERT | INPUT_TRANSFORM_Y_INVERT)
            &zip_xy_scaler 1 2
        >;
    };

    scroller {
        layers = <8>;
        input-processors = <
            &zip_xy_to_scroll_mapper
            &zip_scroll_scaler 1 5
            &zip_scroll_transform INPUT_TRANSFORM_X_INVERT
        >;
    };
};

&size_s_transform {
    col-offset = <7>;
};

&size_m_transform {
    col-offset = <7>;
};

&size_l_transform {
    col-offset = <7>;
};
